{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Filmes",
    "description": "API para gerenciamento de filmes",
    "version": "1.0.0"
  },
  "paths": {
    "/movies": {
      "get": {
        "tags": ["Movies"],
        "summary": "Obter todos os filmes",
        "responses": {
          "200": {
            "description": "Retorna uma lista de filmes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/movies/{id}": {
      "put": {
        "tags": ["Movies"],
        "summary": "Atualizar um filme",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do filme a ser atualizado",
            "schema": {
              "type": "interger"
            }
          }
        ],
        "requestBody":{
            "required": true,
            "content": {
                "application/json": {
                    "schema": {
                        "$ref": "#/components/schemas/MovieInput"
                    }
                }
            }
        },
        "responses": {
          "200": {
            "description": "Filme atualizado com sucesso"  
          },
          "404": {
            "description": "Filme não encontrado"
          },
          "500": {
            "description": "Falha ao atualizar o registro do filme"
          }
        }
      },

      "delete": {
        "tags": ["Movies"],
        "summary": "Remover um filme",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID do filme a ser deletado",
            "schema": {
              "type": "interger"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filme deletado com sucesso"  
          },
          "404": {
            "description": "Filme não encontrado"
          },
          "500": {
            "description": "Falha ao deletar o registro do filme"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Movie": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID do filme"
          },
          "title": {
            "type": "string",
            "description": "Título do filme"
          },
          "genre_id": {
            "type": "integer",
            "description": "Gênero do filme"
          },
          "language_id": {
            "type": "integer",
            "description": "Idioma do filme"
          },
          "oscar_count": {
            "type": "integer",
            "description": "Quantidade de Oscars ganhos pelo filme"
          },
          "release_date": {
            "type": "string",
            "format": "date",
            "description": "Data de lançamento do filme"
          }
        }
      },
      "MovieInput": {
        "type": "object",
        "required": [
            "title",
            "genre_id",
            "language_id",
            "oscar_count",
            "release_date"
        ],
        "properties": {
            "title": {
                "type": "string",
                "description": "Título do filme"
            },
            "genre_id": {
                "type": "integer",
                "description": "ID do gênero do filme"
            },
            "language_id": {
                "type": "integer",
                "description": "ID da lingua do filme"
            },
            "oscar_count": {
                "type": "integer",
                "description": "Quantidade de Oscars ganhos pelo filme"
            },
            "release_date": {
                "type": "string",
                "format": "date",
                "description": "Data de lançamento do filme"
            }
        }
      }
    }
  }
}
